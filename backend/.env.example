# Server Configuration
PORT=3000
NODE_ENV=development

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# JWT Secrets (Change these in production!)
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too

# CORS Configuration (comma-separated for multiple frontend URLs)
CORS_ORIGIN=http://localhost:5173,https://software-testing-finals-xvio-lilac.vercel.app
# Optional: prefix used to auto-allow Vercel preview URLs (*.vercel.app)
CORS_VERCEL_PREFIX=software-testing-finals

# Admin user credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# Firebase Configuration (optional, for Google login)
FIREBASE_SERVICE_ACCOUNT=
